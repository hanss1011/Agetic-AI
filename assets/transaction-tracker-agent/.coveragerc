[run]
omit =
    */extension_telemetry/*
    app/agent_executor.py
    app/extension_capabilities.py
    app/main.py
    app/mcp_client.py

[report]
omit =
    */extension_telemetry/*
    app/agent_executor.py
    app/extension_capabilities.py
    app/main.py
    app/mcp_client.py

[json]
output = coverage.json